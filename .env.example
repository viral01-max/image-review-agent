# ─── Database ───────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/image_review_agent"

# ─── Redis (BullMQ job queue) ───────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AWS (Rekognition + S3) ─────────────────────────────────────
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret_key"
AWS_REGION="us-east-1"
S3_BUCKET_STAGING="brand-images-staging"
S3_BUCKET_PROCESSED="brand-images-processed"
S3_BUCKET_APPROVED="brand-images-approved"

# ─── OpenAI (GPT-4o Vision + DALL-E 3) ──────────────────────────
OPENAI_API_KEY="sk-your-openai-key"

# ─── PhotoRoom ──────────────────────────────────────────────────
PHOTOROOM_API_KEY="your_photoroom_api_key"

# ─── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
